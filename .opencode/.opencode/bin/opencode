#!/bin/bash
# Wrapper for opencode that updates the shared model file when -m/--model is used

# Parse arguments to detect -m/--model
MODEL_ARG=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -m|--model)
            MODEL_ARG="$2"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

# Call the real opencode with all original arguments
/Users/ghostgear/.opencode/bin/opencode_real "$@"

# If a model was specified, update the shared file
if [[ -n "$MODEL_ARG" ]]; then
    echo "$MODEL_ARG" > /Users/ghostgear/.opencode/current_model
    echo "Model updated to: $MODEL_ARG" >&2
fi